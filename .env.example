# Port the app is accessible on your host machine
APP_PORT=4000

# Path to music folder
# Windows: MUSIC_DIR=C:/Users/yourname/Music
# Linux:   MUSIC_DIR=/home/yourname/music
MUSIC_DIR=./music

# Long random string used to sign login tokens — never share this
JWT_SECRET=change-this-to-a-long-random-string

# Admin username (default: admin)
ADMIN_USERNAME=admin

# ADMIN_PASSWORD: intentionally left out.
# On first start, if this is not set, the backend auto-generates
# a random password and prints it ONCE in the logs:
#   docker compose logs backend
# After that, change it inside the app.

# Set to "true" when running behind HTTPS
SECURE_COOKIE=false
